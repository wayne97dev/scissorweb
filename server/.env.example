# --- Duel RPS server config ---

PORT=4000
CLIENT_ORIGIN=http://localhost:3000

# DEMO_MODE=true  -> deposits are a faucet, withdrawals are simulated (no real chain).
# DEMO_MODE=false -> real Solana custody on the RPC below (requires PLATFORM_SECRET).
DEMO_MODE=true

SOLANA_RPC=https://api.devnet.solana.com

# base58-encoded 64-byte secret key of the custodial hot wallet (real mode only).
# Generate with: solana-keygen new -o platform-keypair.json  (then base58-encode the array)
PLATFORM_SECRET=

# Demo faucet drop and bet bounds (lamports). 1 SOL = 1_000_000_000 lamports.
FAUCET_LAMPORTS=1000000000
MIN_BET_LAMPORTS=10000000
MAX_BET_LAMPORTS=10000000000
