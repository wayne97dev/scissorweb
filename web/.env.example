# Public URL of the Duel RPS backend (Socket.IO server).
# Local dev: http://localhost:4000
# Production: set this in Netlify env vars to your deployed server URL.
NEXT_PUBLIC_SERVER_URL=http://localhost:4000

# Solana RPC the wallet/connection uses (devnet for the MVP).
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
